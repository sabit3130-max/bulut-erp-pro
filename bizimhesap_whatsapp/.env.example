# BizimHesap
# BizimHesap panelinizden veya destek ekibinden aldiginiz API bilgilerini girin.
BIZIMHESAP_BASE_URL=https://bizimhesap.com/api/b2b
BIZIMHESAP_CUSTOMERS_ENDPOINT=/customers
BIZIMHESAP_API_KEY=buraya_bizimhesap_api_anahtari
BIZIMHESAP_AUTH_HEADER=Authorization
BIZIMHESAP_AUTH_SCHEME=Bearer
BIZIMHESAP_TIMEOUT_SECONDS=30

# Bazi BizimHesap hesaplarinda sayfalama/alan adlari farkli olabilir.
BIZIMHESAP_PAGE_PARAM=page
BIZIMHESAP_LIMIT_PARAM=limit
BIZIMHESAP_LIMIT=100

# WhatsApp Cloud API
# Meta for Developers > WhatsApp > API Setup alanindan alin.
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=buraya_phone_number_id
WHATSAPP_ACCESS_TOKEN=buraya_meta_access_token

# Onayli template ile gondermek isterseniz doldurun.
# Bos birakilirsa serbest text mesaji denenir.
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=tr

# Gonderim davranisi
MESSAGE_TEMPLATE=Sayin {full_name}, guncel bakiyeniz {balance} TL'dir.
MIN_DELAY_SECONDS=3
MAX_DELAY_SECONDS=9
DEFAULT_COUNTRY_CODE=90
